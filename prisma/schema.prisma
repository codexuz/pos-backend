generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  owner
  seller

  @@map("user_role")
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  trial

  @@map("subscription_status")
}

enum PaymentMethod {
  cash
  card
  transfer
  other

  @@map("payment_method")
}

enum PaymentStatus {
  pending
  partial
  paid
  refunded

  @@map("payment_status")
}

enum TransactionType {
  income
  expense

  @@map("transaction_type")
}

enum Language {
  en
  uz
  ru

  @@map("language")
}

// ─── Subscription Plans ──────────────────────────────────────────────

model SubscriptionPlan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  price        Decimal  @db.Decimal(12, 2)
  durationDays Int      @map("duration_days")
  maxBranches  Int      @default(1) @map("max_branches")
  maxUsers     Int      @default(3) @map("max_users")
  maxProducts  Int      @default(100) @map("max_products")
  features     Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenants Tenant[]

  @@map("subscription_plans")
}

// ─── Tenants ─────────────────────────────────────────────────────────

model Tenant {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  ownerPhone         String             @map("owner_phone")
  language           Language           @default(en)
  subscriptionPlanId String?            @map("subscription_plan_id") @db.Uuid
  subscriptionStatus SubscriptionStatus @default(trial) @map("subscription_status")
  subscriptionStart  DateTime?          @map("subscription_start") @db.Timestamptz
  subscriptionEnd    DateTime?          @map("subscription_end") @db.Timestamptz
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  subscriptionPlan  SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  branches          Branch[]
  users             User[]
  units             Unit[]
  categories        Category[]
  products          Product[]
  clients           Client[]
  sales             Sale[]
  payments          Payment[]
  expenseCategories ExpenseCategory[]
  transactions      Transaction[]
  inventory         Inventory[]

  @@map("tenants")
}

// ─── Branches ────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales        Sale[]
  transactions Transaction[]
  users        User[]

  @@map("branches")
}

// ─── Users ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  phone        String
  passwordHash String   @map("password_hash")
  tenantId     String?  @map("tenant_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  role         UserRole @default(seller)
  fullName     String   @map("full_name")
  language     Language @default(en)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  sales        Sale[]
  transactions Transaction[]

  @@unique([phone, tenantId], map: "users_phone_tenant_idx")
  @@map("users")
}

// ─── Units ───────────────────────────────────────────────────────────

model Unit {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  shortName String   @map("short_name")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("units")
}

// ─── Categories ──────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("categories")
}

// ─── Products ────────────────────────────────────────────────────────

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  categoryId   String?  @map("category_id") @db.Uuid
  unitId       String?  @map("unit_id") @db.Uuid
  name         String
  description  String?
  sku          String?
  barcode      String?
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice Decimal  @default(0) @map("selling_price") @db.Decimal(12, 2)
  imageUrl     String?  @map("image_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  Category?   @relation(fields: [categoryId], references: [id])
  unit      Unit?       @relation(fields: [unitId], references: [id])
  inventory Inventory[]
  saleItems SaleItem[]

  @@map("products")
}

// ─── Inventory ───────────────────────────────────────────────────────

model Inventory {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  quantity    Decimal  @default(0) @db.Decimal(12, 2)
  minQuantity Decimal? @default(0) @map("min_quantity") @db.Decimal(12, 2)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([productId, tenantId], map: "inventory_product_tenant_idx")
  @@map("inventory")
}

// ─── Clients ─────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  fullName  String   @map("full_name")
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales  Sale[]

  @@map("clients")
}

// ─── Sales ───────────────────────────────────────────────────────────

model Sale {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  branchId       String        @map("branch_id") @db.Uuid
  sellerId       String        @map("seller_id") @db.Uuid
  clientId       String?       @map("client_id") @db.Uuid
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  finalAmount    Decimal       @default(0) @map("final_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(pending) @map("payment_status")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch     @relation(fields: [branchId], references: [id])
  seller   User       @relation(fields: [sellerId], references: [id])
  client   Client?    @relation(fields: [clientId], references: [id])
  items    SaleItem[]
  payments Payment[]

  @@map("sales")
}

// ─── Sale Items ──────────────────────────────────────────────────────

model SaleItem {
  id         String  @id @default(uuid()) @db.Uuid
  saleId     String  @map("sale_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Decimal @db.Decimal(12, 2)
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

// ─── Payments ────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  saleId        String?       @map("sale_id") @db.Uuid
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(cash) @map("payment_method")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Expense Categories ──────────────────────────────────────────────

model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("expense_categories")
}

// ─── Transactions ────────────────────────────────────────────────────

model Transaction {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String          @map("tenant_id") @db.Uuid
  branchId          String          @map("branch_id") @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  type              TransactionType
  amount            Decimal         @db.Decimal(12, 2)
  expenseCategoryId String?         @map("expense_category_id") @db.Uuid
  description       String?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch           @relation(fields: [branchId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])

  @@map("transactions")
}
